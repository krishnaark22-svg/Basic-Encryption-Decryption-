import tkinter as tk

def cipher(text, shift):
    result = ""
    for char in text:
        if char.isalpha():
            base = 65 if char.isupper() else 97
            result += chr((ord(char) - base + shift) % 26 + base)
        else:
            result += char
    return result

def encrypt():
    output.set(cipher(entry.get(), int(shift.get())))

def decrypt():
    output.set(cipher(entry.get(), -int(shift.get())))

root = tk.Tk()
root.title("Caesar Cipher")

entry = tk.Entry(root)
entry.pack()

shift = tk.Entry(root)
shift.pack()

output = tk.StringVar()

tk.Button(root, text="Encrypt", command=encrypt).pack()
tk.Button(root, text="Decrypt", command=decrypt).pack()

tk.Label(root, textvariable=output).pack()

root.mainloop()
